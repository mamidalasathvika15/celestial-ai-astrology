{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and cosmic settings",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "The user's ritual name" },
        "zodiacSign": { "type": "string", "description": "The user's sun sign" },
        "birthDate": { "type": "string", "description": "Date of birth" },
        "birthTime": { "type": "string", "description": "Time of birth" },
        "birthLocation": { "type": "string", "description": "Location of birth" },
        "onboarded": { "type": "boolean", "description": "Whether onboarding is complete" },
        "streak": { "type": "number", "description": "Consecutive days of alignment" },
        "lastVisit": { "type": "string", "description": "ISO date of last visit" },
        "isPremium": { "type": "boolean", "description": "Subscription status" }
      },
      "required": ["name", "zodiacSign", "onboarded"]
    },
    "JournalEntry": {
      "title": "JournalEntry",
      "description": "A personal reflection in the cosmic journal",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "content": { "type": "string" }
      },
      "required": ["id", "date", "content"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User account documents"
    },
    "/users/{userId}/journal/{entryId}": {
      "schema": "JournalEntry",
      "description": "User's personal ritual journal"
    }
  }
}
